# Supabase Transaction Pooler connection string (recommended)
# Leave URL empty when using field-based config below.
SUPABASE_TRANSACTION_POOLER_URL=

# Backward-compatible fallback if you already use DATABASE_URL
DATABASE_URL=

# Safer field-based Supabase config (handles special chars in password)
SUPABASE_DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.oyaxebgbdgzfpbwjacxj
SUPABASE_DB_PASSWORD=D2YG&M/QhM_gk.5

# Supabase pooler usually requires SSL
PGSSLMODE=require

# Optional pool tuning
PGPOOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=10000

# Optional CORS whitelist, comma-separated
CORS_ORIGIN=http://localhost:3000

# Local filesystem uploads (default)
UPLOAD_BASE_DIR=

# Optional object storage provider (set to r2 to enable)
STORAGE_PROVIDER=local
R2_ACCOUNT_ID=f9a864dd5dcda562620020d82ff46116
R2_ACCESS_KEY_ID=808bd8dd7d14a9bc55cd44a56221f69a
R2_SECRET_ACCESS_KEY=fa3e98219d7efed11866d8571b83cb454e2a4ccb07aef4dc4e6a605fb17b9690
R2_BUCKET=menu
R2_PUBLIC_BASE_URL=https://f9a864dd5dcda562620020d82ff46116.r2.cloudflarestorage.com/my-images
