# Supabase Transaction Pooler connection string (recommended)
# If password contains special chars, either URL-encode it or use the field-based config below.
SUPABASE_TRANSACTION_POOLER_URL=

# Backward-compatible fallback
DATABASE_URL=

# Safer alternative (recommended when password has special chars)
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# Supabase pooler usually requires SSL
PGSSLMODE=require

# Optional pool tuning
PGPOOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=10000

# Optional CORS whitelist, comma-separated
CORS_ORIGIN=http://localhost:3000,https://menu-frontend-5io.pages.dev

# Local filesystem uploads (default)
UPLOAD_BASE_DIR=

# Optional object storage provider (set to r2 to enable)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://pub-cd641b0d2e9a4297ad5805d0b5b414d8.r2.dev
